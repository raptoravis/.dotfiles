{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(make:*)",
      "mcp__plugin_context-mode_context-mode__batch_execute",
      "mcp__plugin_context-mode_context-mode__execute",
      "mcp__claude_ai_Context7__resolve-library-id",
      "mcp__claude_ai_Context7__query-docs",
      "Bash(powershell -NoProfile -Command \"Get-Process -Name wezterm-gui -ErrorAction SilentlyContinue | Select-Object Id,ProcessName\")"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./credentials.*)",
      "Read(./.credentials.*)",
      "Read(**/*.pem)",
      "Read(**/*id_rsa*)",
      "Read(./build)",
      "Bash(sudo *)",
      "Bash(rm -rf /*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(nc *)",
      "Bash(npm publish *)",
      "Bash(docker push *)",
      "Bash(pip install *)",
      "Bash(brew install *)",
      "Bash(apt install *)",
      "Bash(wrangler deploy *)",
      "Bash(terraform apply *)",
      "Bash(kubectl delete *)"
    ],
    "defaultMode": "bypassPermissions",
    "skipDangerousModePermissionPrompt": true
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun /tmp/bunx-1000-moshi-hooks@latest/node_modules/moshi-hooks/src/index.ts # moshi-hooks",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v graphify >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1 && { if [ -f graphify-out/graph.json ]; then printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"[graphify] 本项目已有知识图谱 (graphify-out/graph.json)。回答架构/跨模块/代码关系类问题前，先读 graphify-out/GRAPH_REPORT.md，并优先用 shell 命令 `graphify query`/`graphify path`/`graphify explain` 而不是裸 grep。代码改动后会通过 PostToolUse 自动跑 shell 命令 `graphify update .`，无需手动。\"}}'; else printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"[graphify] 本项目还没初始化知识图谱。如果用户问架构/跨模块/调用链类问题，建议提示用户在 Claude Code 里输入 slash command：\\n  /graphify .         # 首次构建（这是 Claude skill，不是 shell 命令；会派子代理调 LLM，几分钟，按 token 计费）\\n首次构建完成后，PostToolUse 钩子会在每次 Edit/Write 后自动跑 shell 命令 `graphify update .`（纯 AST 几秒，不调 LLM）。简单查找/编辑可忽略此提示。\"}}'; fi; } || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun /tmp/bunx-1000-moshi-hooks@latest/node_modules/moshi-hooks/src/index.ts # moshi-hooks",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun /tmp/bunx-1000-moshi-hooks@latest/node_modules/moshi-hooks/src/index.ts # moshi-hooks",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bun /tmp/bunx-1000-moshi-hooks@latest/node_modules/moshi-hooks/src/index.ts # moshi-hooks",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun /tmp/bunx-1000-moshi-hooks@latest/node_modules/moshi-hooks/src/index.ts # moshi-hooks",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun /tmp/bunx-1000-moshi-hooks@latest/node_modules/moshi-hooks/src/index.ts # moshi-hooks",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && command -v graphify >/dev/null 2>&1 && (nohup graphify update . >graphify-out/.update.log 2>&1 &) || true",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/statusline.mjs\""
  },
  "enabledPlugins": {
    "context-mode@claude-context-mode": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "handoff@handoff-marketplace": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "zero-review@atum-marketplace": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/claude-context-mode"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "handoff-marketplace": {
      "source": {
        "source": "github",
        "repo": "willseltzer/claude-handoff"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "atum-marketplace": {
      "source": {
        "source": "git",
        "url": "https://github.com/A7um/zero-review.git"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "default",
  "autoMemoryEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "verbose": true
}
